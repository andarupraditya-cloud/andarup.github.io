<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portofolio | Morello Andaru</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome untuk Icon -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        html {
            scroll-behavior: smooth;
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-800 font-sans">

    <!-- Navbar -->
    <nav class="fixed w-full bg-white/80 backdrop-blur-md z-50 shadow-sm">
        <div class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">
            <a href="#" class="text-xl font-bold text-blue-600 tracking-tighter">&lt;MorelloAndaru /&gt;</a>
            <div class="space-x-6 hidden md:block text-sm font-medium">
                <a href="#about" class="hover:text-blue-600 transition">Tentang</a>
                <a href="#skills" class="hover:text-blue-600 transition">Keahlian</a>
                <a href="#projects" class="hover:text-blue-600 transition">Proyek</a>
                <a href="#contact" class="hover:text-blue-600 transition">Kontak</a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="pt-32 pb-20 px-4">
        <div class="max-w-4xl mx-auto text-center">
            <div class="mb-6 inline-block p-1 rounded-full bg-blue-100 px-4 py-1 text-blue-600 text-sm font-semibold">
                Mahasiswa Teknik Informatika 👋
            </div>
            <h1 class="text-4xl md:text-6xl font-extrabold mb-6 leading-tight">
                Halo, Saya <span class="text-blue-600">Morello Andaru</span>
            </h1>
            <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto leading-relaxed">
                Mahasiswa aktif di <strong>Universitas La Tansa Mashiro</strong> yang berfokus pada pengembangan perangkat lunak dan solusi teknologi kreatif.
            </p>
            <div class="flex justify-center gap-4">
                <a href="#projects" class="bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-700 transition shadow-lg shadow-blue-200">Lihat Proyek</a>
                <a href="#contact" class="bg-white border border-gray-200 px-8 py-3 rounded-lg font-semibold hover:bg-gray-50 transition">Hubungi Saya</a>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="py-20 bg-white">
        <div class="max-w-4xl mx-auto px-4 grid md:grid-cols-2 gap-12 items-center">
            <div class="relative">
                <!-- Foto dari Google Drive -->
                <div class="w-full h-96 bg-gray-200 rounded-2xl overflow-hidden shadow-xl">
                    <img src="https://lh3.googleusercontent.com/d/1JwEg1nQrdR91Tt4oE3AM4C4fvSWmhKqi" alt="Morello Andaru" class="w-full h-full object-cover">
                </div>
                <div class="absolute -bottom-6 -right-6 w-32 h-32 bg-blue-600 rounded-2xl -z-10"></div>
            </div>
            <div>
                <h2 class="text-3xl font-bold mb-6">Tentang Saya</h2>
                <p class="text-gray-600 mb-4">
                    Saya adalah mahasiswa programmer dari <strong>Universitas La Tansa Mashiro</strong>. Memiliki semangat tinggi dalam mempelajari teknologi baru, khususnya di bidang Web Development dan Problem Solving.
                </p>
                <p class="text-gray-600 mb-6">
                    Melalui perkuliahan dan pembelajaran mandiri, saya terus mengasah kemampuan logika pemrograman saya untuk membangun aplikasi yang efisien dan bermanfaat bagi pengguna.
                </p>
                <div class="flex gap-4 text-2xl text-gray-400">
                    <a href="#" class="hover:text-blue-600"><i class="fab fa-github"></i></a>
                    <a href="#" class="hover:text-blue-600"><i class="fab fa-linkedin"></i></a>
                    <a href="#" class="hover:text-blue-600"><i class="fab fa-instagram"></i></a>
                </div>
            </div>
        </div>
    </section>

    <!-- Skills Section -->
    <section id="skills" class="py-20 bg-gray-50">
        <div class="max-w-4xl mx-auto px-4">
            <h2 class="text-3xl font-bold mb-12 text-center">Tech Stack</h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                <div class="bg-white p-6 rounded-xl shadow-sm text-center hover:shadow-md transition border-b-4 border-orange-500">
                    <i class="fab fa-html5 text-4xl text-orange-500 mb-3"></i>
                    <p class="font-bold">HTML & CSS</p>
                </div>
                <div class="bg-white p-6 rounded-xl shadow-sm text-center hover:shadow-md transition border-b-4 border-yellow-400">
                    <i class="fab fa-js text-4xl text-yellow-400 mb-3"></i>
                    <p class="font-bold">JavaScript</p>
                </div>
                <div class="bg-white p-6 rounded-xl shadow-sm text-center hover:shadow-md transition border-b-4 border-blue-500">
                    <i class="fab fa-python text-4xl text-blue-500 mb-3"></i>
                    <p class="font-bold">Python</p>
                </div>
                <div class="bg-white p-6 rounded-xl shadow-sm text-center hover:shadow-md transition border-b-4 border-blue-600">
                    <i class="fas fa-database text-4xl text-blue-600 mb-3"></i>
                    <p class="font-bold">SQL / DBMS</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Projects Section -->
    <section id="projects" class="py-20 bg-white">
        <div class="max-w-6xl mx-auto px-4">
            <h2 class="text-3xl font-bold mb-12 text-center">Proyek Saya</h2>
            <div class="grid md:grid-cols-3 gap-8">
                
                <!-- Project Card 1 -->
                <div class="group bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition duration-300">
                    <div class="h-48 bg-gray-100">
                         <img src="https://via.placeholder.com/600x400?text=Proyek+Kuliah" alt="Project 1" class="w-full h-full object-cover">
                    </div>
                    <div class="p-6">
                        <h3 class="font-bold text-xl mb-2">Sistem Informasi Kampus</h3>
                        <p class="text-gray-600 text-sm mb-4">Pengembangan sistem manajemen data mahasiswa sederhana untuk tugas besar.</p>
                        <div class="flex gap-2 flex-wrap mb-6">
                            <span class="px-3 py-1 bg-blue-50 text-blue-600 text-xs rounded-full font-bold">PHP</span>
                            <span class="px-3 py-1 bg-blue-50 text-blue-600 text-xs rounded-full font-bold">MySQL</span>
                        </div>
                    </div>
                </div>

                <!-- Project Card 2 -->
                <div class="group bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition duration-300">
                    <div class="h-48 bg-gray-100">
                         <img src="https://via.placeholder.com/600x400?text=Landing+Page" alt="Project 2" class="w-full h-full object-cover">
                    </div>
                    <div class="p-6">
                        <h3 class="font-bold text-xl mb-2">Personal Portfolio</h3>
                        <p class="text-gray-600 text-sm mb-4">Website portofolio responsif menggunakan Tailwind CSS.</p>
                        <div class="flex gap-2 flex-wrap mb-6">
                            <span class="px-3 py-1 bg-blue-50 text-blue-600 text-xs rounded-full font-bold">HTML</span>
                            <span class="px-3 py-1 bg-blue-50 text-blue-600 text-xs rounded-full font-bold">Tailwind</span>
                        </div>
                    </div>
                </div>

                <!-- Project Card 3 -->
                <div class="group bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition duration-300">
                    <div class="h-48 bg-gray-100">
                         <img src="https://via.placeholder.com/600x400?text=Python+Script" alt="Project 3" class="w-full h-full object-cover">
                    </div>
                    <div class="p-6">
                        <h3 class="font-bold text-xl mb-2">Automation Tool</h3>
                        <p class="text-gray-600 text-sm mb-4">Script Python sederhana untuk otomatisasi pengolahan data teks.</p>
                        <div class="flex gap-2 flex-wrap mb-6">
                            <span class="px-3 py-1 bg-blue-50 text-blue-600 text-xs rounded-full font-bold">Python</span>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="py-20 bg-blue-600 text-white">
        <div class="max-w-4xl mx-auto px-4 text-center">
            <h2 class="text-3xl font-bold mb-4">Ayo Terhubung!</h2>
            <p class="mb-10 text-blue-100">Saya Morello Andaru, siap berkolaborasi dalam proyek pemrograman atau diskusi teknologi.</p>
            <div class="flex flex-col md:flex-row justify-center gap-8">
                <a href="mailto:email-kamu@gmail.com" class="flex items-center justify-center gap-3 bg-white text-blue-600 px-6 py-3 rounded-lg font-bold hover:bg-gray-100 transition">
                    <i class="fas fa-envelope"></i> Kirim Email
                </a>
                <a href="#" class="flex items-center justify-center gap-3 border border-white px-6 py-3 rounded-lg font-bold hover:bg-white/10 transition">
                    <i class="fab fa-linkedin"></i> LinkedIn
                </a>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="py-10 text-center text-gray-500 text-sm">
        <p>&copy; 2024 Morello Andaru - Universitas La Tansa Mashiro.</p>
